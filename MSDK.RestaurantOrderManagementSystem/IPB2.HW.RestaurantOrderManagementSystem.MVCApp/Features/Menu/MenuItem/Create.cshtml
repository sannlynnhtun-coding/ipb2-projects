@using IPB2.HW.RestaurantOrderManagementSystem.Domain.Features.Menu
@model CreateMenuItemRequest

@{
    ViewData["Title"] = "Add Menu Item";
    var categories = ViewBag.Categories as List<CategoryDto>;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-5">
                    <h2 class="fw-bold text-center mb-4 text-success">New Menu Item</h2>
                    <form asp-action="MenuItemSave" method="post">
                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label text-dark small fw-bold text-uppercase">Item Name</label>
                                <input asp-for="Name" class="form-control form-control-lg border-2" placeholder="e.g. Garlic Bread" required />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label text-dark small fw-bold text-uppercase">Price ($)</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control form-control-lg border-2" placeholder="0.00" required />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CategoryId" class="form-label text-dark small fw-bold text-uppercase">Category</label>
                            <select asp-for="CategoryId" class="form-select form-select-lg border-2" required>
                                <option value="">-- Select Category --</option>
                                @if (categories != null)
                                {
                                    foreach (var cat in categories)
                                    {
                                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" role="switch" checked>
<label class="form-check-label fw-bold text-dark" asp-for="IsAvailable">Available for Order</label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">Save Menu Item</button>
                            <a asp-action="MenuItemIndex" class="btn btn-light btn-lg text-dark">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
