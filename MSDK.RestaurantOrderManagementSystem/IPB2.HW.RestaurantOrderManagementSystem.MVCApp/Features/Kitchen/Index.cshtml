@model IPB2.HW.RestaurantOrderManagementSystem.Domain.Features.Kitchen.PendingOrderListResponse

@{
    ViewData["Title"] = "Kitchen Display";
}

<div class="container mt-4">
    <h2 class="display-6 fw-bold mb-4 text-danger"><i class="bi bi-fire"></i> Kitchen Display</h2>

    <div class="row g-4 text-center">
        @if (Model.Data != null && Model.Data.Any())
        {
            foreach (var order in Model.Data)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-danger text-white border-0 py-3 d-flex justify-content-between">
                            <h5 class="mb-0">Order #@order.OrderId</h5>
                            <span class="badge bg-white text-danger">Table @order.TableNumber</span>
                        </div>
                        <div class="card-body">
                            <ul class="list-group list-group-flush text-start">
                                @foreach (var item in order.OrderItems)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                                        <span>@item.Quantity x Item ID: @item.MenuItemId</span>
                                    </li>
                                }
                            </ul>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-4">
                            <form asp-action="UpdateStatus" method="post" class="d-flex gap-2 justify-content-center">
                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                <button type="submit" name="status" value="Processing" class="btn btn-warning btn-sm px-3">Start</button>
                                <button type="submit" name="status" value="Completed" class="btn btn-success btn-sm px-3">Finish</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-light border-0 shadow-sm rounded-4 p-5">
                    <i class="bi bi-emoji-smile fs-1 text-dark d-block mb-3"></i>
                    <h4 class="text-dark">No pending orders. Take a break!</h4>
                </div>
            </div>
        }
    </div>
</div>
