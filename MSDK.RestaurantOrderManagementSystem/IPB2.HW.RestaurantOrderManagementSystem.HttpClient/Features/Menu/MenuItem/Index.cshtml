@model IPB2.HW.RestaurantOrderManagementSystem.Domain.Features.Menu.MenuItemListResponse

@{
    ViewData["Title"] = "Menu Items";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="display-6 fw-bold text-success">Menu Items</h2>
        <a asp-action="MenuItemCreate" class="btn btn-success btn-lg shadow-sm">
            <i class="bi bi-plus-lg"></i> Add New Menu Item
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light text-secondary text-uppercase small fw-bold">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="ps-4 fw-medium text-dark">@item.MenuItemId</td>
                            <td class="fw-bold text-dark">@item.Name</td>
                            <td class="text-success fw-bold">$@item.Price.ToString("F2")</td>
                            <td>
                                <span class="fw-bold text-dark">@item.CategoryName</span>
                            </td>
                            <td>
                                @if (item.IsAvailable == true)
                                {
                                    <span class="badge bg-success-subtle text-success-emphasis rounded-pill px-3 py-1"><i class="bi bi-check-circle-fill me-1"></i> Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger-emphasis rounded-pill px-3 py-1"><i class="bi bi-x-circle-fill me-1"></i> Sold Out</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="MenuItemEdit" asp-route-id="@item.MenuItemId" class="btn btn-outline-warning btn-sm border-0 me-2">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="MenuItemDelete" asp-route-id="@item.MenuItemId" class="btn btn-outline-danger btn-sm border-0" onclick="return confirm('Are you sure you want to delete this menu item?')">
                                    <i class="bi bi-trash3"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.PageCount; i++)
            {
                <li class="page-item @(i == Model.PageNo ? "active" : "")">
                    <a class="page-link shadow-sm mx-1 rounded-3" asp-action="MenuItemIndex" asp-route-pageNo="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>
