@model IPB2.HW.RestaurantOrderManagementSystem.Domain.Features.Menu.CreateCategoryRequest

@{
    ViewData["Title"] = "Add Category";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-5">
                    <h2 class="fw-bold text-center mb-4">New Category</h2>
                    <form asp-action="CategorySave" method="post">
                        <div class="mb-4">
                            <label asp-for="CategoryName" class="form-label text-dark small fw-bold text-uppercase">Category Name</label>
                            <input asp-for="CategoryName" class="form-control form-control-lg border-2" placeholder="e.g. Appetizers" required />
                            <span asp-validation-for="CategoryName" class="text-danger small"></span>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">Save Category</button>
                            <a asp-action="CategoryIndex" class="btn btn-light btn-lg text-dark">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
