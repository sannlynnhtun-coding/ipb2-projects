@model IPB2.HW.RestaurantOrderManagementSystem.Domain.Features.Payment.PaymentListResponse

@{
    ViewData["Title"] = "Payments";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="display-6 fw-bold text-dark"><i class="bi bi-wallet2 text-primary"></i> Payments</h2>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light text-secondary text-uppercase small fw-bold">
                    <tr>
                        <th class="ps-4">Payment ID</th>
                        <th>Order ID</th>
                        <th>Date</th>
                        <th>Method</th>
                        <th>Amount</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="ps-4 fw-medium text-dark">#@item.PaymentId</td>
                            <td><span class="badge bg-secondary-subtle text-dark rounded-pill px-3">Order #@item.OrderId</span></td>
                            <td class="text-dark">@item.PaymentDate?.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>
                                <span class="fw-bold text-dark">@item.PaymentMethod</span>
                            </td>
                            <td class="fw-bold text-success">$@item.TotalAmount?.ToString("F2")</td>
                            <td class="text-end pe-4">
                                <a asp-action="Delete" asp-route-id="@item.PaymentId" class="btn btn-outline-danger btn-sm border-0" onclick="return confirm('Delete this payment record?')">
                                    <i class="bi bi-trash3"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.PageCount; i++)
            {
                <li class="page-item @(i == Model.PageNo ? "active" : "")">
                    <a class="page-link shadow-sm mx-1 rounded-3" asp-action="Index" asp-route-pageNo="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>
