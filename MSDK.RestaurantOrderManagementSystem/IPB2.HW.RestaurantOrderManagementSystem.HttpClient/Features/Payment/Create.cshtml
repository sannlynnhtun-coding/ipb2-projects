@model IPB2.HW.RestaurantOrderManagementSystem.Domain.Features.Payment.CreatePaymentRequest

@{
    ViewData["Title"] = "Process Payment";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <i class="bi bi-credit-card-2-front text-primary display-1"></i>
                    </div>
                    <h2 class="fw-bold mb-2">Checkout</h2>
                    <p class="text-muted mb-4">Order #@Model.OrderId</p>
                    
                    <div class="bg-light p-4 rounded-4 mb-4">
                        <span class="text-dark small fw-bold text-uppercase d-block mb-1">Total Amount</span>
                        <h1 class="display-4 fw-bold text-success">$@Model.TotalAmount?.ToString("F2")</h1>
                    </div>

                    <form asp-action="Save" method="post">
                        <input type="hidden" asp-for="OrderId" />
                        <input type="hidden" asp-for="TotalAmount" />
                        
                        <div class="mb-4 text-start">
                            <label asp-for="PaymentMethod" class="form-label text-secondary small fw-bold text-uppercase">Payment Method</label>
                            <select asp-for="PaymentMethod" class="form-select form-select-lg border-2" required>
                                <option value="Cash">Cash</option>
                                <option value="Credit Card">Credit Card</option>
                                <option value="Mobile Wallet">Mobile Wallet</option>
                            </select>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm py-3 fw-bold">Pay Now</button>
                            <a asp-controller="Order" asp-action="Index" class="btn btn-light btn-lg text-dark">Back to Orders</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
