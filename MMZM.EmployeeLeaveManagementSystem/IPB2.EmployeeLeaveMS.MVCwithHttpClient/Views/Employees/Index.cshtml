@model EmployeeListResponseModel
@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">Employee Directory</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus-fill me-2"></i>Add Employee
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px; background: rgba(34, 197, 94, 0.1); color: #15803d;">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light text-muted small text-uppercase fw-semibold">
                    <tr>
                        <th class="ps-4">Code</th>
                        <th>Name</th>
                        <th>Department</th>
                        <th>Position</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var emp in Model.Employees)
                    {
                        <tr id="row-@emp.EmployeeId">
                            <td class="ps-4 align-middle fw-medium">@emp.EmployeeCode</td>
                            <td class="align-middle">@emp.EmployeeName</td>
                            <td class="align-middle"><span class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill shadow-none" style="background: rgba(99, 102, 241, 0.1);">@emp.Department</span></td>
                            <td class="align-middle text-secondary">@emp.Position</td>
                            <td class="text-end pe-4 align-middle">
                                <a asp-action="Edit" asp-route-id="@emp.EmployeeId" class="btn btn-sm btn-light border me-1 rounded-3">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <button onclick="deleteEmployee(@emp.EmployeeId)" class="btn btn-sm btn-light border text-danger rounded-3">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteEmployee(id) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#6366f1',
                cancelButtonColor: '#ef4444',
                confirmButtonText: 'Yes, delete it!',
                background: 'rgba(255, 255, 255, 0.9)',
                backdrop: `blur(4px)`
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Employees")',
                        type: 'POST',
                        data: { id: id },
                        success: function (res) {
                            if (res.isSuccess) {
                                Swal.fire({
                                    title: 'Deleted!',
                                    text: res.message,
                                    icon: 'success',
                                    confirmButtonColor: '#6366f1'
                                });
                                $('#row-' + id).fadeOut();
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        }
                    });
                }
            })
        }
    </script>
}
