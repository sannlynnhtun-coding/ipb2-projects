@model EmployeeCreateRequestModel
@{
    ViewData["Title"] = "Add Employee";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-light border rounded-3 me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="fw-bold m-0">Add New Employee</h1>
        </div>

        <div class="card border-0 p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="EmployeeCode" class="form-label fw-medium">Employee Code</label>
                        <input asp-for="EmployeeCode" class="form-control" placeholder="EMP-001" required />
                        <span asp-validation-for="EmployeeCode" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EmployeeName" class="form-label fw-medium">Full Name</label>
                        <input asp-for="EmployeeName" class="form-control" placeholder="John Doe" required />
                        <span asp-validation-for="EmployeeName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-medium">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="john@example.com" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label fw-medium">Phone Number</label>
                        <input asp-for="Phone" class="form-control" placeholder="+1 234 567 890" required />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Department" class="form-label fw-medium">Department</label>
                        <select asp-for="Department" class="form-select" required>
                            <option value="">Select Department</option>
                            <option value="IT">IT</option>
                            <option value="HR">HR</option>
                            <option value="Finance">Finance</option>
                            <option value="Marketing">Marketing</option>
                            <option value="Operations">Operations</option>
                        </select>
                        <span asp-validation-for="Department" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Position" class="form-label fw-medium">Position</label>
                        <input asp-for="Position" class="form-control" placeholder="Senior Developer" required />
                        <span asp-validation-for="Position" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="JoinDate" class="form-label fw-medium">Join Date</label>
                        <input asp-for="JoinDate" type="date" class="form-control" required />
                        <span asp-validation-for="JoinDate" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mt-5 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save me-2"></i>Create Employee
                    </button>
                    <a asp-action="Index" class="btn btn-light border px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-control, .form-select {
        border-radius: 10px;
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
    }
    .form-control:focus, .form-select:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }
</style>
