@model LeaveTypeCreateRequestModel
@{
    ViewData["Title"] = "Add Leave Type";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-light border rounded-3 me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="fw-bold m-0">Create Leave Type</h1>
        </div>

        <div class="card border-0 p-4 shadow-sm">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label asp-for="LeaveTypeName" class="form-label fw-bold">Leave Type Name</label>
                    <input asp-for="LeaveTypeName" class="form-control form-control-lg border-0 bg-light rounded-4" placeholder="e.g., Annual Leave" required />
                    <span asp-validation-for="LeaveTypeName" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="MaxDaysPerYear" class="form-label fw-bold">Default Annual Limit (Days)</label>
                    <div class="input-group">
                        <input asp-for="MaxDaysPerYear" type="number" class="form-control form-control-lg border-0 bg-light rounded-start-4" placeholder="10" min="1" required />
                        <span class="input-group-text border-0 bg-light rounded-end-4 text-muted fw-medium px-4">Days</span>
                    </div>
                    <span asp-validation-for="MaxDaysPerYear" class="text-danger small"></span>
                </div>

                <div class="pt-3">
                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-4">
                        <i class="bi bi-check-circle-fill me-2"></i>Create Leave Type
                    </button>
                    <a asp-action="Index" class="btn btn-link w-100 mt-2 text-decoration-none text-muted">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1) !important;
    }
</style>
