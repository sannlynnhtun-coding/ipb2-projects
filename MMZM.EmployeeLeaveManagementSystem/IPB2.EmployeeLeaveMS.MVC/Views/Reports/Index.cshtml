@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="mb-5">
    <h1 class="fw-bold m-0">Reports & Analytics</h1>
    <p class="text-muted">Gain insights into leave patterns and employee summaries.</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-6">
        <div class="card border-0 h-100 shadow-sm p-4">
            <h4 class="fw-bold mb-4"><i class="bi bi-calendar-check me-2 text-primary"></i>Monthly Leave Report</h4>
            <div class="row g-2">
                <div class="col-8 col-sm-6">
                    <div class="row g-2">
                        <div class="col-7">
                            <select id="reportMonth" class="form-select border-0 bg-light rounded-3">
                                @for (int i = 1; i <= 12; i++)
                                {
                                    <option value="@i" selected="@(i == DateTime.Now.Month)">@System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(i)</option>
                                }
                            </select>
                        </div>
                        <div class="col-5">
                            <input id="reportYear" type="number" class="form-control border-0 bg-light rounded-3" value="@DateTime.Now.Year" />
                        </div>
                    </div>
                </div>
                <div class="col-4 col-sm-6 text-end">
                    <button onclick="loadMonthlyReport()" class="btn btn-primary rounded-3 w-100 w-sm-auto">
                        Generate
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 h-100 shadow-sm p-4">
            <h4 class="fw-bold mb-4"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Employee Leave Summary</h4>
            <div class="row g-2">
                <div class="col-8 col-sm-6">
                    <select id="employeeId" asp-items="ViewBag.Employees" class="form-select border-0 bg-light rounded-3">
                        <option value="">All Employees</option>
                    </select>
                </div>
                <div class="col-4 col-sm-6 text-end">
                    <button onclick="loadEmployeeSummary()" class="btn btn-primary rounded-3 w-100 w-sm-auto">
                        Generate
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="reportResult" class="mt-4">
    <div class="text-center py-5 text-muted opacity-50">
        <i class="bi bi-clipboard-data display-1 d-block mb-3"></i>
        <span>Select options above to generate a report.</span>
    </div>
</div>

@section Scripts {
    <script>
        function loadMonthlyReport() {
            const m = $('#reportMonth').val();
            const y = $('#reportYear').val();
            $('#reportResult').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>');
            $.get('@Url.Action("MonthlyReport", "Reports")', { year: y, month: m }, function (data) {
                $('#reportResult').html(data);
            });
        }

        function loadEmployeeSummary() {
            const id = $('#employeeId').val();
            $('#reportResult').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>');
            $.get('@Url.Action("EmployeeSummary", "Reports")', { employeeId: id }, function (data) {
                $('#reportResult').html(data);
            });
        }
    </script>
}
