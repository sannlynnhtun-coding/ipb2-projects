@model EmployeeLeaveSummaryResponseModel

<div class="card border-0 shadow-sm overflow-hidden animate__animated animate__fadeIn">
    <div class="card-header bg-white py-3 border-0">
        <h5 class="fw-bold m-0 text-primary">Employee Summary Results</h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted small text-uppercase">
                <tr>
                    <th class="ps-4">Employee</th>
                    <th>Leave Type</th>
                    <th class="pe-4">Usage (Taken / Max)</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Summary.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center py-5 text-muted">No summary data available.</td>
                    </tr>
                }
                @foreach (var item in Model.Summary)
                {
                    <tr>
                        <td class="ps-4">
                            <span class="fw-bold">@item.EmployeeName</span>
                        </td>
                        <td><span class="badge bg-soft-primary text-primary" style="background: rgba(99, 102, 241, 0.1);">@item.LeaveTypeName</span></td>
                        <td class="pe-4 fw-bold text-indigo" style="color: #6366f1;">@item.TotalLeavesTaken / @item.MaxLeaves Days</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
