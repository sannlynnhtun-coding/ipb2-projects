@model MonthlyLeaveReportResponseModel

<div class="card border-0 shadow-sm overflow-hidden animate__animated animate__fadeIn">
    <div class="card-header bg-white py-3 border-0">
        <h5 class="fw-bold m-0 text-primary">Monthly Report Results</h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted small text-uppercase">
                <tr>
                    <th class="ps-4">Employee</th>
                    <th>Code</th>
                    <th>Department</th>
                    <th>Leave Type</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th class="pe-4 text-end">Days</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Leaves.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">No leave records found for this period.</td>
                    </tr>
                }
                @foreach (var item in Model.Leaves)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.EmployeeName</td>
                        <td>@item.EmployeeCode</td>
                        <td><span class="badge bg-light text-dark border">@item.Department</span></td>
                        <td>@item.LeaveTypeName</td>
                        <td class="small">@item.StartDate.ToShortDateString()</td>
                        <td class="small">@item.EndDate.ToShortDateString()</td>
                        <td class="pe-4 text-end fw-bold">@item.TotalDays</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
