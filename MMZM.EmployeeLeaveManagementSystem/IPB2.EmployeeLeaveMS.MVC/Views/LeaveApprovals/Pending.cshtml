@model List<LeaveRequestDto>
@{
    ViewData["Title"] = "Pending Approvals";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold m-0">Pending Approvals</h1>
        <p class="text-muted">Review and process employee leave applications.</p>
    </div>
    <a asp-action="Index" class="btn btn-light border px-4 rounded-3">
        <i class="bi bi-clock-history me-2"></i>View History
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success border-0 shadow-sm mb-4 rounded-4 py-3">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm mb-4 rounded-4 py-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
    </div>
}

<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="card border-0 p-5 text-center bg-white">
                <div class="mb-3 text-muted">
                    <i class="bi bi-inbox fs-1"></i>
                </div>
                <h3 class="fw-bold">All caught up!</h3>
                <p class="text-muted">There are no pending leave requests to process at this time.</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var req in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 p-3 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-4">
                            <div class="flex-shrink-0 bg-primary-soft p-3 rounded-circle" style="background: rgba(99, 102, 241, 0.1);">
                                <i class="bi bi-person-circle fs-4 text-primary"></i>
                            </div>
                            <div class="ms-3">
                                <h5 class="fw-bold mb-0">@req.EmployeeName</h5>
                                <span class="text-muted small">@req.LeaveTypeName</span>
                            </div>
                        </div>

                        <div class="bg-light p-3 rounded-4 mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-secondary small">Duration</span>
                                <span class="fw-bold">@req.TotalDays Days</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-secondary small">Dates</span>
                                <span class="small fw-medium">@req.StartDate.ToShortDateString() - @req.EndDate.ToShortDateString()</span>
                            </div>
                        </div>

                        <p class="text-muted small mb-4" style="min-height: 48px;">
                            <i class="bi bi-quote me-2 opacity-50"></i>@req.Reason
                        </p>

                        <form asp-action="Approve" method="post" class="d-inline">
                            <input type="hidden" name="LeaveRequestId" value="@req.LeaveRequestId" />
                            <input type="hidden" name="ApprovedBy" value="@ViewBag.DefaultApproverId" />
                            <div class="mb-3">
                                <input name="Comments" class="form-control border-0 bg-light rounded-3 small" placeholder="Add comments..." />
                            </div>
                            <div class="d-grid gap-2 d-md-flex">
                                <button type="submit" class="btn btn-success flex-grow-1 rounded-3 py-2">
                                    <i class="bi bi-check2-circle me-1"></i>Approve
                                </button>
                                <button type="submit" asp-action="Reject" class="btn btn-outline-danger flex-grow-1 rounded-3 py-2">
                                    <i class="bi bi-x-circle me-1"></i>Reject
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>
