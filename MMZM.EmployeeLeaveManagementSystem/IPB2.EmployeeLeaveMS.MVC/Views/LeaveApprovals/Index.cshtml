@model LeaveApprovalListResponseModel
@{
    ViewData["Title"] = "Approval History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold m-0">Approval History</h1>
        <p class="text-muted">Tracking all processed leave applications.</p>
    </div>
    <a asp-action="Pending" class="btn btn-primary px-4 rounded-3">
        <i class="bi bi-plus-circle me-2"></i>Process Pending
    </a>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted small text-uppercase">
                <tr>
                    <th class="ps-4">Record Info</th>
                    <th>Employee & Type</th>
                    <th>Status</th>
                    <th>Processed By</th>
                    <th class="pe-4">Comments</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var approval in Model.Approvals)
                {
                    <tr>
                        <td class="ps-4">
                            <span class="d-block fw-bold">#@approval.ApprovalId</span>
                            <span class="text-muted small">@approval.ApprovalDate.ToString("MMM dd, yyyy")</span>
                        </td>
                        <td>
                            <span class="d-block fw-medium">@approval.EmployeeName</span>
                            <span class="badge bg-light text-secondary border">@approval.LeaveTypeName</span>
                        </td>
                        <td>
                            @{
                                var statusClass = approval.ApprovalStatus == "Approved" ? "bg-success" : "bg-danger";
                            }
                            <span class="badge @statusClass rounded-pill px-3 py-2">@approval.ApprovalStatus</span>
                        </td>
                        <td>
                            <i class="bi bi-person-check me-2 text-primary"></i>@approval.ApproverName
                        </td>
                        <td class="pe-4">
                            <span class="text-muted small">@(string.IsNullOrEmpty(approval.Comments) ? "No comments provided." : approval.Comments)</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
