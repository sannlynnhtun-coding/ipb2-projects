@model LeaveRequestCreateRequestModel
@{
    ViewData["Title"] = "Apply for Leave";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-light border rounded-3 me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="fw-bold m-0">Leave Application</h1>
        </div>

        <div class="card border-0 p-4 shadow-sm">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-12">
                        <label asp-for="EmployeeId" class="form-label fw-bold">Select Employee</label>
                        <select asp-for="EmployeeId" asp-items="ViewBag.Employees" class="form-select form-select-lg border-0 bg-light rounded-4" required>
                            <option value="">-- Select Employee --</option>
                        </select>
                        <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="LeaveTypeId" class="form-label fw-bold">Leave Type</label>
                        <select asp-for="LeaveTypeId" asp-items="ViewBag.LeaveTypes" class="form-select form-select-lg border-0 bg-light rounded-4" required>
                            <option value="">-- Select Type --</option>
                        </select>
                        <span asp-validation-for="LeaveTypeId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 text-muted">
                        <label class="form-label fw-bold">Duration</label>
                        <p class="small">The number of days will be calculated automatically based on the dates selected.</p>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label fw-bold">Start Date</label>
                        <input asp-for="StartDate" type="date" class="form-control form-control-lg border-0 bg-light rounded-4" required />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label fw-bold">End Date</label>
                        <input asp-for="EndDate" type="date" class="form-control form-control-lg border-0 bg-light rounded-4" required />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Reason" class="form-label fw-bold">Reason for Leave</label>
                        <textarea asp-for="Reason" class="form-control border-0 bg-light rounded-4" rows="3" placeholder="Please provide a brief explanation..."></textarea>
                        <span asp-validation-for="Reason" class="text-danger small"></span>
                    </div>
                </div>

                <div class="pt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-lg px-5 rounded-4 shadow-sm">
                        <i class="bi bi-send-check-fill me-2"></i>Submit Application
                    </button>
                    <a asp-action="Index" class="btn btn-light btn-lg px-4 border rounded-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-select, .form-control {
        padding: 1rem 1.25rem;
    }
    .form-select:focus, .form-control:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1) !important;
        border-color: #6366f1 !important;
    }
</style>
