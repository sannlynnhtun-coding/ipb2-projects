@model LeaveRequestListResponseModel
@{
    ViewData["Title"] = "Leave Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">Leave Requests</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-send-fill me-2"></i>Apply for Leave
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px; background: rgba(34, 197, 94, 0.1); color: #15803d;">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Employee</th>
                        <th>Type</th>
                        <th>Period</th>
                        <th>Days</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var req in Model.LeaveRequests)
                    {
                        <tr id="row-@req.LeaveRequestId">
                            <td class="ps-4 align-middle">
                                <span class="fw-bold d-block text-dark">@req.EmployeeName</span>
                                <span class="text-muted small">ID: #@req.EmployeeId</span>
                            </td>
                            <td class="align-middle fw-medium">@req.LeaveTypeName</td>
                            <td class="align-middle">
                                <span class="small text-secondary">@req.StartDate.ToShortDateString() - @req.EndDate.ToShortDateString()</span>
                            </td>
                            <td class="align-middle">@req.TotalDays Days</td>
                            <td class="align-middle">
                                @{
                                    var statusClass = req.Status switch
                                    {
                                        "Pending" => "bg-warning-soft text-warning",
                                        "Approved" => "bg-success-soft text-success",
                                        "Rejected" => "bg-danger-soft text-danger",
                                        _ => "bg-secondary-soft text-secondary"
                                    };
                                }
                                <span class="badge @statusClass px-3 py-2 rounded-pill shadow-none" 
                                      style="background-color: @(req.Status == "Pending" ? "rgba(245, 158, 11, 0.1)" : (req.Status == "Approved" ? "rgba(34, 197, 94, 0.1)" : "rgba(239, 68, 68, 0.1)"))">
                                    <i class="bi bi-circle-fill me-1 tiny"></i>@req.Status
                                </span>
                            </td>
                            <td class="text-end pe-4 align-middle">
                                <button onclick="deleteRequest(@req.LeaveRequestId)" class="btn btn-sm btn-light border text-danger rounded-3">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .tiny { font-size: 0.5rem; vertical-align: middle; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteRequest(id) {
            Swal.fire({
                title: 'Cancel Request?',
                text: "This request will be permanently removed.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, cancel it!',
                background: 'rgba(255, 255, 255, 0.9)',
                backdrop: `blur(4px)`
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "LeaveRequests")',
                        type: 'POST',
                        data: { id: id },
                        success: function (res) {
                            if (res.isSuccess) {
                                Swal.fire('Cancelled!', res.message, 'success');
                                $('#row-' + id).fadeOut();
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        }
                    });
                }
            })
        }
    </script>
}
