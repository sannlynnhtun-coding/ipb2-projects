@model IEnumerable<IBP2.StudentResultManagementSystemMVC.Models.ResultModel>

@{
    ViewData["Title"] = "Results";
    int pageNo = ViewBag.PageNo;
    int pageSize = ViewBag.PageSize;
    int totalCount = ViewBag.TotalCount;
    int totalPages = (int)Math.Ceiling((double)totalCount / pageSize);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold text-indigo">Examination Results</h1>
        <a asp-action="Create" class="btn btn-indigo btn-lg shadow-sm text-white">
            <i class="bi bi-plus-circle-fill"></i> Record New Result
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-indigo">
                    <tr>
                        <th class="ps-4">Student</th>
                        <th>Subject</th>
                        <th>Marks</th>
                        <th>Grade</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-indigo-light text-indigo rounded-circle me-3 d-flex align-items-center justify-content-center">
                                            @item.Student.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold">@item.Student.Name</div>
                                            <div class="small text-muted">@item.Student.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@item.Subject.Name</div>
                                    <div class="small text-muted">@item.Subject.Credits Credits</div>
                                </td>
                                <td>
                                    <span class="fw-bold">@item.Marks</span> / 100
                                </td>
                                <td>
                                    @{
                                        string badgeClass = item.Grade switch
                                        {
                                            "A+" or "A" => "bg-success",
                                            "B" or "C" => "bg-primary",
                                            "D" => "bg-warning text-dark",
                                            _ => "bg-danger"
                                        };
                                    }
                                    <span class="badge @badgeClass rounded-pill px-3">@item.Grade</span>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-indigo btn-sm">
                                        Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <p class="mb-0">No results found. Start recording grades!</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <div class="card-footer bg-white py-3 border-top-0">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item @(pageNo == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pageNo="@(pageNo - 1)" asp-route-pageSize="@pageSize">Previous</a>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == pageNo ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-pageNo="@i" asp-route-pageSize="@pageSize">@i</a>
                            </li>
                        }
                        <li class="page-item @(pageNo == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pageNo="@(pageNo + 1)" asp-route-pageSize="@pageSize">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .text-indigo { color: #6610f2; }
        .bg-indigo { background-color: #6610f2; }
        .btn-indigo { background-color: #6610f2; border-color: #6610f2; }
        .btn-indigo:hover { background-color: #520dc2; border-color: #520dc2; }
        .btn-outline-indigo { color: #6610f2; border-color: #6610f2; }
        .btn-outline-indigo:hover { background-color: #6610f2; color: white; }
        .bg-indigo-light { background-color: rgba(102, 16, 242, 0.1); }
        .avatar-sm { width: 32px; height: 32px; font-size: 0.8rem; }
        .table-hover tbody tr:hover {
            background-color: rgba(102, 16, 242, 0.05);
            transition: background-color 0.2s ease-in-out;
        }
        .pagination .page-link { color: #6610f2; }
        .pagination .active .page-link { background-color: #6610f2; border-color: #6610f2; }
    </style>
}
