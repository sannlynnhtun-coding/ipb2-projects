@model IBP2.StudentResultManagementSystemMVC.Models.UpdateResultRequest

@{
    ViewData["Title"] = "Update Result";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-warning text-dark p-4 rounded-top-4">
                    <h2 class="h4 mb-0 fw-bold">Update Result Record</h2>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="mb-4">
                            <label asp-for="StudentId" class="form-label fw-semibold text-secondary">Student</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-person text-warning"></i>
                                </span>
                                <select asp-for="StudentId" class="form-select bg-light border-start-0 ps-0" asp-items="ViewBag.Students">
                                </select>
                            </div>
                            <span asp-validation-for="StudentId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="SubjectId" class="form-label fw-semibold text-secondary">Subject</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-book text-warning"></i>
                                </span>
                                <select asp-for="SubjectId" class="form-select bg-light border-start-0 ps-0" asp-items="ViewBag.Subjects">
                                </select>
                            </div>
                            <span asp-validation-for="SubjectId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-5">
                            <label asp-for="Marks" class="form-label fw-semibold text-secondary">Obtained Marks</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-check2-circle text-warning"></i>
                                </span>
                                <input asp-for="Marks" type="number" class="form-control bg-light border-start-0 ps-0" placeholder="Enter marks (0-100)" min="0" max="100" />
                            </div>
                            <span asp-validation-for="Marks" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-warning btn-lg shadow-sm py-3 fw-bold">
                                Update Result
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .form-select:focus, .form-control:focus {
            background-color: #fff !important;
            border-color: #ffc107;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.15);
        }
        .input-group-text { color: #6c757d; }
    </style>
}
