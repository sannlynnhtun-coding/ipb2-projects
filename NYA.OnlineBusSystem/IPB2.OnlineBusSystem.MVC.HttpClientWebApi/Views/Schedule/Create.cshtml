@using IPB2.OnlineBusSystem.Domain.Features.Bus
@using IPB2.OnlineBusSystem.Domain.Features.Route
@using IPB2.OnlineBusSystem.Domain.Features.Schedule
@model UpsertScheduleRequest
<!-- Create Schedule Modal -->
<div class="modal fade" id="createScheduleModal" tabindex="-1" aria-labelledby="createScheduleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="createScheduleModalLabel"><i class="fas fa-plus-circle me-2"></i>Create New Schedule</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" asp-controller="Schedule" method="post">
                <div class="modal-body px-4 py-4">
                    <div class="row g-4">
                        <!-- Bus Selection -->
                        <div class="col-md-6">
                            <label asp-for="BusId" class="form-label fw-bold small text-uppercase">Bus</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-bus text-muted"></i></span>
                                <select asp-for="BusId" class="form-select border-start-0" required>
                                    <option value="">-- Select Bus --</option>
                                    @if (ViewBag.Buses != null)
                                    {
                                        foreach (var bus in (List<BusComboSetModel>)ViewBag.Buses)
                                        {
                                            <option value="@bus.Id">@bus.BusName</option>
                                        }
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="BusId" class="text-danger small"></span>
                        </div>

                        <!-- Route Selection -->
                        <div class="col-md-6">
                            <label asp-for="RouteId" class="form-label fw-bold small text-uppercase">Route</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-route text-muted"></i></span>
                                <select asp-for="RouteId" class="form-select border-start-0" required>
                                    <option value="">-- Select Route --</option>
                                    @if (ViewBag.Routes != null)
                                    {
                                        foreach (var route in (List<RouteComboSetModel>)ViewBag.Routes)
                                        {
                                            <option value="@route.Id">@route.RouteName (@route.Origin-@route.Destination)</option>
                                        }
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="RouteId" class="text-danger small"></span>
                        </div>

                        <!-- Date -->
                        <div class="col-md-4">
                            <label asp-for="Date" class="form-label fw-bold small text-uppercase">Schedule Date</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-calendar-alt text-muted"></i></span>
                                <input asp-for="Date" type="date" class="form-control border-start-0" required />
                            </div>
                            <span asp-validation-for="Date" class="text-danger small"></span>
                        </div>

                        <!-- Departure Time -->
                        <div class="col-md-4">
                            <label asp-for="DepartureTime" class="form-label fw-bold small text-uppercase">Departure Time</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-clock text-muted"></i></span>
                                <input asp-for="DepartureTime" type="time" class="form-control border-start-0" required />
                            </div>
                            <span asp-validation-for="DepartureTime" class="text-danger small"></span>
                        </div>

                        <!-- Arrival Time -->
                        <div class="col-md-4">
                            <label asp-for="ArrivalTime" class="form-label fw-bold small text-uppercase">Arrival Time</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-history text-muted"></i></span>
                                <input asp-for="ArrivalTime" type="time" class="form-control border-start-0" required />
                            </div>
                            <span asp-validation-for="ArrivalTime" class="text-danger small"></span>
                        </div>

                        <!-- Fare -->
                        <div class="col-md-6">
                            <label asp-for="Fare" class="form-label fw-bold small text-uppercase">Fare (Amount)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-money-bill-wave text-muted"></i></span>
                                <input asp-for="Fare" type="number" step="100" min="0" class="form-control border-start-0" required placeholder="e.g. 25000" />
                            </div>
                            <span asp-validation-for="Fare" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 px-4 py-3">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success px-4 shadow-sm">
                        <i class="fas fa-save me-1"></i> Save Schedule
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
