@{
    ViewData["Title"] = "Home Page";
    ViewData["FullWidth"] = true;
}

<div class="hero-wrapper">
    <img src="~/images/bus-ticketing-system1.jpg" alt="Bus Ticketing System" class="hero-bg" asp-append-version="true" />
    <div class="hero-overlay"></div>
    <div class="hero-container">
        <div class="hero-glass-box animate__animated animate__fadeInUp">
            <h1 class="hero-title">Online Bus System</h1>
            <p class="hero-subtitle">
                Experience the most reliable and efficient bus booking system.
                Your journey, our priority. Book your tickets in minutes and travel with comfort.
            </p>
            <div class="hero-actions">
                <a asp-controller="Booking" asp-action="Index" class="btn btn-hero-primary">
                    <i class="fa-solid fa-magnifying-glass me-2"></i> Book Now
                </a>
                @* <a asp-action="Privacy" class="btn btn-hero-outline">
                    <i class="fa-solid fa-circle-info me-2"></i> Learn More
                </a> *@
            </div>
        </div>
    </div>
</div>
