@using IPB2.OnlineBusSystem.Domain.Features.Route
@model UpsertRouteRequest
<!-- Edit Bus Modal -->
<div class="modal fade" id="editRouteModal" tabindex="-1" aria-labelledby="editRouteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="editBusModalLabel"><i class="fas fa-edit me-2"></i>Edit Route Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Edit" asp-controller="Route" method="post">
                <input type="hidden" name="Id" id="editRouteId" />
                <div class="modal-body px-4 py-4">
                    <div class="mb-4">
                        <label asp-for="RouteName" class="form-label fw-bold small text-uppercase">Route Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="fas fa-id-card text-muted"></i>
                            </span>
                            <input asp-for="RouteName" id="editRouteName" class="form-control border-start-0" required />
                        </div>
                        <span asp-validation-for="RouteName" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Origin" class="form-label fw-bold small text-uppercase">Origin</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="fas fa-bus text-muted"></i>
                            </span>
                            <input asp-for="Origin" id="editOrigin" class="form-control border-start-0" required  />
                        </div>
                        <span asp-validation-for="Origin" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Destination" class="form-label fw-bold small text-uppercase">Destination</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="fas fa-tag text-muted"></i>
                            </span>
                            <input asp-for="Destination" id="editDestination" class="form-control border-start-0" required />
                        </div>
                        <span asp-validation-for="Destination" class="text-danger small"></span>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 px-4 py-3">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm">
                        <i class="fas fa-save me-1"></i> Update Route
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

