@using IPB2.OnlineBusSystem.Domain.Features.Route
@model GetRoutesResponse
@{
    ViewData["Title"] = "Route Management";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary mb-0"> <i class="fa-solid fa-route"></i>Route Management</h2>
            <p class="text-muted small mb-0">Manage your route details.</p>
        </div>
        <button type="button" class="btn btn-success px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#createRouteModal">
            <i class="fas fa-plus-circle me-1"></i> Add New Route
        </button>
    </div>    
</div>

<!-- Route Table -->
<div class="container">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">All Route List</h3>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th >Route Name</th>
                            <th >Origin</th>
                            <th >Destination</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.Routes != null && Model.Routes.Any())
                        {
                            foreach (var route in Model.Routes)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold">@route.RouteName</span>
                                    </td>
                                    <td>@route.Origin</td>
                                    <td>@route.Destination</td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <button type="button" class="btn btn-sm btn-outline-primary" title="Edit"
                                                    data-bs-toggle="modal" data-bs-target="#editRouteModal"
                                                    data-id="@route.Id" data-name="@route.RouteName" data-origin="@route.Origin"
                                                    data-destination="@route.Destination">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-danger ms-1" title="Delete"
                                                    data-bs-toggle="modal" data-bs-target="#deleteRouteModal"
                                                    data-id="@route.Id" data-name="@route.RouteName">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="text-muted mb-3">
                                        <i class="fas fa-folder-open fa-3x opacity-25"></i>
                                    </div>
                                    <h5 class="text-muted">No Route Records Found</h5>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
     </<div>
</div>
</div>
</div>

<!-- Modal Partials -->
<partial name="Create" />
<partial name="Edit" model="new UpsertRouteRequest()" />
<partial name="Delete" />
<style>
    .card {
        transition: transform 0.2s;
    }

    .btn-group .btn {
        padding: 0.35rem 0.6rem;
    }

    .page-link {
        border-radius: 8px !important;
        margin: 0 3px;
        color: #333;
        border: 1px solid #dee2e6;
    }

    .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }
</style>
@section Scripts {
    <script>
        // Edit Modal Data Sync
        const editRouteModal = document.getElementById('editRouteModal');
        if (editRouteModal) {
            editRouteModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const name = button.getAttribute('data-name');
                const origin = button.getAttribute('data-origin');
                const destination = button.getAttribute('data-destination');

                editRouteModal.querySelector('#editRouteId').value = id;
                editRouteModal.querySelector('#editRouteName').value = name;
                editRouteModal.querySelector('#editOrigin').value = origin;
                editRouteModal.querySelector('#editDestination').value = destination;
            });
        }

        // Delete Modal Data Sync
        const deleteRouteModal = document.getElementById('deleteRouteModal');
        if (deleteRouteModal) {
            deleteRouteModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const name = button.getAttribute('data-name');

                deleteRouteModal.querySelector('#deleteRouteId').value = id;
                deleteRouteModal.querySelector('#deleteRouteDisplay').textContent = name;
            });
        }
    </script>
}
