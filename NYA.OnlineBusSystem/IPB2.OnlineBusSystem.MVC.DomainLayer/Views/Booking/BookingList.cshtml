@using IPB2.OnlineBusSystem.Domain.Features.Booking
@model BookingDetailResponse
@{
    ViewData["Title"] = "My Bookings";
}

<!-- Search Card -->
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary mb-0">
                <i class="fas fa-list-check me-2"></i> Find Your Bookings
            </h2>
            <p class="text-muted small mb-0">Find your booking history.</p>
        </div>
    </div>           
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <form method="get" class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-muted">Username</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-muted"></i></span>
                                <input type="text" name="username" class="form-control border-start-0" 
                                       placeholder="Enter your name" value="@Context.Request.Query["username"]" required />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-muted">Phone Number</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-phone text-muted"></i></span>
                                <input type="text" name="phoneno" class="form-control border-start-0" 
                                       placeholder="Enter your phone number" value="@Context.Request.Query["phoneno"]" required />
                            </div>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100 shadow-sm">
                                <i class="fas fa-search me-1"></i> Search
                            </button>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <a asp-action="BookingList" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-undo me-1"></i> Reset
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Results Section -->
            @if (Model?.bookings != null && Model.bookings.Any())
            {
                <div class="row row-cols-1 g-3">
                    @foreach (var booking in Model.bookings)
                    {
                        <div class="col">
                            <div class="card border-0 shadow-sm overflow-hidden">
                                <div class="row g-0">
                                    <div class="col-md-3 bg-light p-4 d-flex flex-column justify-content-center text-center border-end">
                                        <div class="text-primary h5 mb-1">@booking.BookedBusName</div>
                                        <div class="badge bg-primary mb-2">@booking.BookedBusType</div>
                                        <div class="small text-muted fw-bold">No: @booking.BookedBusNo</div>
                                    </div>
                                    <div class="col-md-6 p-4">
                                        <div class="row mb-3">
                                            <div class="col">
                                                <div class="small text-muted text-uppercase fw-bold">Origin</div>
                                                <div class="h6 mb-0">@booking.BookedOrigin</div>
                                                <div class="small text-primary">@booking.BookedDepartureTime</div>
                                            </div>
                                            <div class="col-auto d-flex align-items-center">
                                                <i class="fas fa-long-arrow-alt-right text-muted opacity-50"></i>
                                            </div>
                                            <div class="col">
                                                <div class="small text-muted text-uppercase fw-bold">Destination</div>
                                                <div class="h6 mb-0">@booking.BookedDestination</div>
                                                <div class="small text-primary">@booking.BookedArrivalTime</div>
                                            </div>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <span class="badge bg-light text-dark border me-2 py-2 px-3">
                                                <i class="fas fa-chair me-1 text-primary"></i> Seat #@booking.SeatNo
                                            </span>
                                            <span class="text-muted small">
                                                <i class="fas fa-calendar-alt me-1"></i> @booking.TravelDate.ToString("MMM dd, yyyy")
                                            </span>
                                        </div>
                                    </div>
                                    <div class="col-md-3 p-4 bg-light d-flex flex-column justify-content-center text-center border-start">
                                        <div class="small text-muted mb-1">Total Paid</div>
                                        <div class="h4 text-success mb-0">@booking.BookedFare.ToString("N0") <small class="h6">Ks</small></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (Context.Request.Query.ContainsKey("username"))
            {
                <div class="text-center py-5">
                    <div class="text-muted mb-3 opacity-25">
                        <i class="fas fa-search fa-5x"></i>
                    </div>
                    <h4 class="text-muted">No Bookings Found</h4>
                    <p class="text-muted small">We couldn't find any records for "@Context.Request.Query["username"]" with that phone number.</p>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <div class="text-muted mb-3 opacity-10">
                        <i class="fas fa-ticket-alt fa-7x"></i>
                    </div>
                    <h5 class="text-muted">Enter your details to view your transaction history</h5>
                </div>
            }
        </div>
    </div>
</div>
