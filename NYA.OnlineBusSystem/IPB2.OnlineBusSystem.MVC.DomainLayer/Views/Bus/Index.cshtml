@using IPB2.OnlineBusSystem.Domain.Features.Bus
@model GetBusResponse
@{
    ViewData["Title"] = "Bus Management";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary mb-0"><i class="fas fa-bus-alt me-2"></i>Bus Management</h2>
            <p class="text-muted small mb-0">Manage your bus fleet details and availability.</p>
        </div>
        <button type="button" class="btn btn-success px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#createBusModal">
            <i class="fas fa-plus-circle me-1"></i> Add New Bus
        </button>
    </div>
    <!-- Search Section -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 bg-light rounded-3">
            <form method="get" asp-action="Index">
                <div class="row g-3">
                    <div class="col-lg-7 col-md-6">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="fas fa-search text-muted"></i>
                            </span>
                            <input type="text" name="searchTerm" class="form-control border-start-0 ps-0" 
                                   placeholder="Search by bus name, number or type..." 
                                   value="@Context.Request.Query["searchTerm"]">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100 shadow-sm">
                            <i class="fas fa-filter me-1"></i> Search
                        </button>
                    </div>
                    <div class="col-md-2">
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-undo me-1"></i> Reset
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
    <!-- Bus Table -->
<div class="container">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">All Bus List</h3>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Bus No</th>
                            <th>Bus Name</th>
                            <th>Type</th>
                            <th class="text-center">Seats</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.Buss != null && Model.Buss.Any())
                        {
                            foreach (var bus in Model.Buss)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold">@bus.BusNo</span>
                                    </td>
                                    <td>@bus.BusName</td>
                                    <td>
                                        <span class="badge rounded-pill bg-info text-dark px-3">@bus.BusType</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border px-3">@bus.TotalSeat</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <button type="button" class="btn btn-sm btn-outline-primary" title="Edit"
                                                    data-bs-toggle="modal" data-bs-target="#editBusModal"
                                                    data-id="@bus.Id" data-no="@bus.BusNo" data-name="@bus.BusName"
                                                    data-type="@bus.BusType" data-seats="@bus.TotalSeat">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-danger ms-1" title="Delete"
                                                    data-bs-toggle="modal" data-bs-target="#deleteBusModal"
                                                    data-id="@bus.Id" data-no="@bus.BusNo">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="text-muted mb-3">
                                        <i class="fas fa-folder-open fa-3x opacity-25"></i>
                                    </div>
                                    <h5 class="text-muted">No Bus Records Found</h5>
                                    <p class="small text-muted mb-0">Try adjusting your search or add a new bus to the list.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
     </div>

    <!-- Pagination -->
    @if (Model != null && Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                    <a class="page-link shadow-sm" href="?pageNumber=@(Model.PageNumber - 1)&searchTerm=@Context.Request.Query["searchTerm"]">
                        <i class="fas fa-chevron-left me-1"></i> Previous
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link shadow-sm" href="?pageNumber=@i&searchTerm=@Context.Request.Query["searchTerm"]">@i</a>
                    </li>
                }
                <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link shadow-sm" href="?pageNumber=@(Model.PageNumber + 1)&searchTerm=@Context.Request.Query["searchTerm"]">
                        Next <i class="fas fa-chevron-right ms-1"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    .card {
        transition: transform 0.2s;
    }
    .btn-group .btn {
        padding: 0.35rem 0.6rem;
    }
    .page-link {
        border-radius: 8px !important;
        margin: 0 3px;
        color: #333;
        border: 1px solid #dee2e6;
    }
    .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }
</style>

<!-- Modal Partials -->
<partial name="Create" />
<partial name="Edit" model="new UpdateBusRequest()" />

<partial name="Delete" />

@section Scripts {
    <script>
        // Edit Modal Data Sync
        const editBusModal = document.getElementById('editBusModal');
        if (editBusModal) {
            editBusModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const no = button.getAttribute('data-no');
                const name = button.getAttribute('data-name');
                const type = button.getAttribute('data-type');
                const seats = button.getAttribute('data-seats');

                editBusModal.querySelector('#editBusId').value = id;
                editBusModal.querySelector('#editBusNo').value = no;
                editBusModal.querySelector('#editBusName').value = name;
                editBusModal.querySelector('#editBusType').value = type;
                editBusModal.querySelector('#editTotalSeat').value = seats;
            });
        }

        // Delete Modal Data Sync
        const deleteBusModal = document.getElementById('deleteBusModal');
        if (deleteBusModal) {
            deleteBusModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const no = button.getAttribute('data-no');

                deleteBusModal.querySelector('#deleteBusId').value = id;
                deleteBusModal.querySelector('#deleteBusNoDisplay').textContent = no;
            });
        }
    </script>
}
